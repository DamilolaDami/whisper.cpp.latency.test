{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"exec /app/whisper-server --host 0.0.0.0 --port ${PORT} --threads ${THREADS} --model /app/models/ggml-${MODEL}.bin\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
